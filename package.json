{
  "name": "mipiacetpv",
  "version": "0.0.0",
  "private": true,
  "description": "TPV web multi-tenant integrado con Holded",
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:api": "pnpm --filter @mipiacetpv/api dev",
    "dev:admin": "pnpm --filter @mipiacetpv/admin dev",
    "dev:tpv": "pnpm --filter @mipiacetpv/tpv-web dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @mipiacetpv/db run generate",
    "db:migrate": "pnpm --filter @mipiacetpv/db run migrate",
    "db:studio": "pnpm --filter @mipiacetpv/db run studio",
    "spike:05": "pnpm --filter @mipiacetpv/spike-holded run 05-final-flow",
    "spike:06": "pnpm --filter @mipiacetpv/spike-holded run 06-pay-pdf-freeline",
    "spike:07": "pnpm --filter @mipiacetpv/spike-holded run 07-test-productid",
    "spike:08": "pnpm --filter @mipiacetpv/spike-holded run 08-account-info",
    "spike:09": "pnpm --filter @mipiacetpv/spike-holded run 09-webhooks-probe"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "vitest": "^2.1.4"
  }
}
