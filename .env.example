# mipiacetpv · variables de entorno
#
# Copia este archivo a .env y rellena los huecos. Nunca commitees .env.
# Cada workspace tiene su propio .env opcional (apps/api/.env,
# spike/holded/.env); este de raíz centraliza todo y `dotenv -e ../../.env`
# desde los workspaces lo lee. En CI, las variables se inyectan a mano.

# ── Base de datos ─────────────────────────────────────────────────────
# El docker-compose.yml de raíz expone Postgres en localhost:5432 con
# las credenciales mipiacetpv / mipiacetpv_dev. Producción usa otras.
DATABASE_URL="postgresql://mipiacetpv:mipiacetpv_dev@localhost:5432/mipiacetpv?schema=public"

# ── Redis (BullMQ + caché de sesión) ──────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── API ───────────────────────────────────────────────────────────────
PORT=3001
# Origen del admin y del TPV para CORS (lista separada por comas).
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"
PUBLIC_URL="https://mipiacetpv.tech"

# ── Auth (JWT del propietario y refresh) ──────────────────────────────
# Generar con `openssl rand -base64 48`. NUNCA reutilizar entre entornos.
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
# Formato @fastify/jwt: "15m", "1h", "7d".
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
# TTL del refresh cuando el propietario marca "Recuérdame" en login (B2 §4.3).
JWT_REFRESH_TTL_REMEMBER="90d"

# ── Cifrado simétrico de la API Key de Holded ─────────────────────────
# AES-256-GCM key, 32 bytes base64. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotar => re-cifrar todos los tenants. NO perderla — sin ella las keys
# en BD son ilegibles.
HOLDED_KEY_ENCRYPTION_SECRET=""

# ── Holded OAuth (v2, ADR-004) ────────────────────────────────────────
# Quedan reservadas para v2; en MVP cada tenant aporta su API Key vía
# /onboarding/connect-holded.
HOLDED_OAUTH_CLIENT_ID=""
HOLDED_OAUTH_CLIENT_SECRET=""
HOLDED_OAUTH_REDIRECT_URI="https://mipiacetpv.tech/api/oauth/holded/callback"

# ── Email (B3 §17.4 + §17.6) ──────────────────────────────────────────
# SMTP del remitente del email de alertas (nuevo dispositivo) y de los
# enlaces de password reset. En NODE_ENV=development se pueden dejar
# vacíos: el EmailSender cae al ConsoleEmailSender (los emails se
# loguean a stdout en vez de enviarse).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="mipiacetpv <no-reply@mipiacetpv.tech>"
# URL pública del admin — la usamos para construir el link del email
# de password reset (`${PUBLIC_ADMIN_URL}/admin/reset?token=…`).
PUBLIC_ADMIN_URL="http://localhost:5173"

# ── Holded (opcional — sólo para apps/tpv-web-spike) ──────────────────
# El TPV productivo NO usa estas: las keys viven en tenant.holdedApiKeyCiphertext.
# Estas sólo permiten que el super-mini-MVP del spike siga arrancando como
# referencia viva durante B1-B3.
HOLDED_API_KEY=""
HOLDED_BASE_URL="https://api.holded.com/api"
