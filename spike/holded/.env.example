# Copia este archivo a `.env` y rellena los valores.
# El `.env` real está en .gitignore.

# API Key de Holded. La pega aquí Matías. Header HTTP literal: `key: <valor>`.
HOLDED_API_KEY=

# URL base. Se mantiene la del legacy salvo que la doc oficial diga otra.
HOLDED_BASE_URL=https://api.holded.com/api

# Serie de prueba para los salesreceipt que crearemos en scripts 03+.
# No tocar series fiscales reales del cliente.
HOLDED_TEST_NUMSERIE=TPV-SPIKE-01

# OAuth (vacío hasta que registremos app en developers.holded.com).
HOLDED_OAUTH_CLIENT_ID=
HOLDED_OAUTH_CLIENT_SECRET=
HOLDED_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
