// Schema Prisma para mipiacetpv.
// Fuente: docs/06-modelo-datos.md.
//
// El bloque "multi-tenant raíz" incluye register/device/pairing_code
// desde el día 1 porque el flujo de emparejamiento es parte del MVP
// (docs/01-spec-funcional.md §3.2).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  CASHIER
}

enum HoldedAuthMode {
  API_KEY
  OAUTH
}

enum TicketStatus {
  DRAFT
  PAID
  PENDING_SYNC
  SYNCED
  SYNC_FAILED
  VOIDED
  // B-OnboardingV2: ticket creado por un cajero técnico interno (modo
  // prueba). El worker `ticket-upload-worker` lo identifica y NO sube a
  // Holded (skip silencioso). Al activar el tenant los tickets TEST se
  // purgan junto con el cajero técnico.
  TEST
}

enum PaymentMethod {
  CASH
  CARD
  BIZUM
  VOUCHER
  OTHER
}

enum ProductKind {
  PRODUCT
  SERVICE
}

enum SyncOutboxKind {
  UPLOAD_TICKET
  UPLOAD_REFUND
  CATALOG_SYNC
}

enum SyncOutboxStatus {
  PENDING
  DONE
  DEAD
}

enum HoldedUploadKind {
  TICKET
  REFUND
}

enum HoldedUploadStatus {
  PENDING
  DONE
  FAILED
}

enum TableZone {
  SALON
  TERRAZA
  BARRA
  RESERVADO
}

enum InitialSyncStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// B-OnboardingV2: ciclo de vida del onboarding supervisado del tenant.
//
//   DRAFT  → tenant creado con API key Holded, sync inicial corriendo
//            o terminada. Sin OWNER. El equipo mipiacetpv prueba el TPV
//            con un cajero técnico. Los tickets generados no suben a
//            Holded ni se envían por email.
//   ACTIVE → el equipo ha validado salud, el super-admin ha introducido
//            email + nombre del propietario. Se ha creado el OWNER user,
//            enviado el email de bienvenida y purgado los datos de
//            prueba. A partir de aquí operación productiva real.
//
// READY se calcula on-the-fly desde `onboardingHealth.ready` (Frente 3
// del prompt): es un check de heurística sobre el sync inicial,
// productos sellable, taxes, etc. No es un valor persistido — el
// listado super-admin lo pinta cuando `state=DRAFT` y `ready=true`.
enum OnboardingState {
  DRAFT
  ACTIVE
}

// B-Multi-Vertical: vertical de negocio del tenant. Define
// comportamientos del TPV:
//   - HOSPITALITY: mapa de mesas activo, modificadores tipo bar, placeholder
//                  icono café (vertical original — Thalia, bares).
//   - RETAIL:      sin mapa de mesas, modificadores opcionales (variantes
//                  de producto), placeholder icono paquete (librería,
//                  ropa, etc.).
//   - SERVICES:    sin mapa de mesas, sin modificadores, placeholder
//                  icono maletín (consultorías, talleres, peluquerías).
// Default RETAIL porque al introducir el campo el piloto inicial
// (Librería Thalia) ya es retail; los tenants futuros lo eligen al alta.
enum BusinessType {
  HOSPITALITY
  RETAIL
  SERVICES
}

// v1.3-Thalia Lote 4 · arqueo de caja. El cajero cuenta efectivo por
// denominaciones (no un total libre como antes). X = control intermedio
// sin cerrar turno; Z = control de cierre — generamos sólo uno Z por
// shift, X puede haber varios.
enum ShiftCashCountKind {
  X
  Z
}

// v1.3-Thalia Lote 3 · intent de impresión persistido. Hasta este
// lote el TPV sólo tenía `Ticket.printIntent: Boolean` (intención del
// primer cobro). Ahora hace falta crear un intent por cada reimpresión
// posterior, así que pasamos a una tabla con `kind`:
//   - NEW: impresión original al cobrar (la que vivía implícita en el
//     boolean). El handler de cobro la crea cuando `printIntent=true`.
//   - REPRINT: el cajero pidió una copia desde el historial. El
//     renderer del ticket pinta "COPIA — no fiscal" en cabecera.
//   - GIFT: ticket regalo (el `giftReceiptIntentAt` del Ticket se
//     mantiene como timestamp informativo, pero el intent vive aquí).
// Status libre (PENDING|DONE|FAILED) sin enum para no acoplar al
// ciclo Prisma — el bridge B5 lo consumirá vía BullMQ cuando se monte.
enum PrintIntentKind {
  NEW
  REPRINT
  GIFT
}

// ── Multi-tenant raíz ─────────────────────────────────────────────────

model Tenant {
  id                             String            @id @default(uuid()) @db.Uuid
  name                           String
  holdedAccountId                String?           @map("holded_account_id")
  holdedAuthMode                 HoldedAuthMode    @default(API_KEY) @map("holded_auth_mode")
  // Tokens y API keys siempre cifrados con AES-GCM antes de persistir.
  holdedApiKeyCiphertext         String?           @map("holded_api_key_ciphertext")
  holdedOauthAccess              String?           @map("holded_oauth_access")
  holdedOauthRefresh             String?           @map("holded_oauth_refresh")
  holdedOauthExpiresAt           DateTime?         @map("holded_oauth_expires_at") @db.Timestamptz()
  // Datos fiscales agregados (NIF, razón social, dirección) extraídos
  // del almacén default o introducidos por el propietario. Van al pie
  // de cada ticket impreso.
  fiscalProfile                  Json?             @map("fiscal_profile")
  // Estado del sync inicial post-onboarding. El admin pollea
  // GET /onboarding/sync-status para mostrar la barra de progreso.
  initialSyncStatus              InitialSyncStatus @default(PENDING) @map("initial_sync_status")
  initialSyncStartedAt           DateTime?         @map("initial_sync_started_at") @db.Timestamptz()
  initialSyncCompletedAt         DateTime?         @map("initial_sync_completed_at") @db.Timestamptz()
  // Stats acumulados: productsCount, servicesCount, warehousesCount,
  // taxesCount, autoSkuFixed, autoSkuNeedsReview, wildcardsCreated,
  // wildcardsReused, errors[]. Estructura libre; el admin la pinta.
  initialSyncStats               Json?             @map("initial_sync_stats")
  // Última vez que el sync incremental (B2 §2) corrió con éxito sobre
  // este tenant. El cron de 15 min lo actualiza; el admin lo muestra
  // como "última sincronización hace X min".
  lastIncrementalSyncAt          DateTime?         @map("last_incremental_sync_at") @db.Timestamptz()
  // Última vez que el catálogo de contactos se refrescó (B7 §8). Se
  // actualiza al final del sync incremental tras descargar todos los
  // contactos de Holded. Sirve para que el admin distinga entre un
  // sync "completo" y uno parcial.
  lastContactsSyncAt             DateTime?         @map("last_contacts_sync_at") @db.Timestamptz()
  // Stats del último sync incremental: { productsSeen, productsUpdated,
  // orphansMarked, autoSkuFixed, autoSkuNeedsReview, durationMs,
  // errors[] }. Mismo enfoque que `initialSyncStats` — estructura
  // libre, el admin la renderiza.
  lastIncrementalSyncStats       Json?             @map("last_incremental_sync_stats")
  // Minutos sin actividad antes de que la PWA cierre la sesión del cajero
  // (§17.2). El turno sigue abierto; sólo se cae la sesión. Rango sensato
  // 5–60 min.
  cashierAutoLogoutMinutes       Int               @default(10) @map("cashier_auto_logout_minutes")
  // Si true, el cierre forzado de un turno colgado de otro cajero exige
  // PIN de encargado cuando el cajero actual no lo es. Default true.
  requireManagerPinForForceClose Boolean           @default(true) @map("require_manager_pin_for_force_close")
  // Si true, se envía email al propietario cuando un device nuevo se
  // empareja o cuando un device conocido aparece desde un país distinto
  // (§17.4). Default true.
  deviceNewLoginAlertEnabled     Boolean           @default(true) @map("device_new_login_alert_enabled")
  // Umbral de descuento (%) que el cajero puede aplicar sin autorización
  // del encargado (B6 §2). Si supera este porcentaje, el TPV pide PIN
  // encargado y el backend exige `authorizationToken` en POST /tickets.
  discountThresholdPct           Decimal           @default(10) @map("discount_threshold_pct") @db.Decimal(5, 2)
  // Si true, el cajero puede buscar contactos Holded desde el TPV. Si
  // false, sólo OWNER/MANAGER puede asociar contacto a un ticket. Por
  // defecto true para no romper el flujo actual.
  cashierSearchableContacts      Boolean           @default(true) @map("cashier_searchable_contacts")
  // B-SuperAdmin: bloqueo global del tenant. NULL = activo. NOT NULL =
  // bloqueado por super-admin. El middleware `requireTenantNotBlocked`
  // corta TODAS las requests per-tenant con 423 Locked cuando esto está
  // set, independientemente del rol del solicitante.
  blockedAt                      DateTime?         @map("blocked_at") @db.Timestamptz()
  blockedReason                  String?           @map("blocked_reason")
  // Plan operativo (gestionado manualmente por el super-admin). String
  // libre — no enum — para no requerir migración al añadir tiers.
  plan                           String?
  // B-OnboardingV2: estado del onboarding supervisado. DRAFT al crear
  // sólo con API key Holded (sin OWNER user todavía). ACTIVE tras pasar
  // por POST /super-admin/tenants/:id/activate (crea OWNER, manda email,
  // purga datos de prueba). El backfill de la migración pone ACTIVE en
  // todos los tenants existentes para no romper el flujo legacy.
  onboardingState                OnboardingState   @default(DRAFT) @map("onboarding_state")
  // B-Multi-Vertical: vertical operativo del tenant. Default RETAIL
  // para no asumir hostelería en tenants nuevos (el piloto inicial es
  // librería). Editable desde la consola super-admin.
  businessType                   BusinessType      @default(RETAIL) @map("business_type")
  // v1.3-Thalia Lote 6 · pie de ticket personalizado. NULL = no se
  // pinta nada extra (comportamiento previo). Si está set, el renderer
  // del ticket lo pinta arriba del QR/CIF tras el "Gracias por tu
  // visita". Limitado a 200 caracteres en el endpoint admin para no
  // descuajeringar el layout (~5 líneas en 80mm).
  receiptFooter                  String?           @map("receipt_footer")
  // v1.3-hotfix6 · subvertical del tenant para elegir el icono
  // placeholder de la grid del TPV cuando un producto/servicio no
  // tiene imagen. NULL = icono genérico del businessType. Valores
  // soportados: "haircut", "medical", "auto_repair", "beauty",
  // "fitness", "education" (texto libre, el TPV mapea a icono lucide).
  tpvIconPreset                  String?           @map("tpv_icon_preset")
  createdAt                      DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                      DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  users          User[]
  stores         Store[]
  devices        Device[]
  pairingCodes   PairingCode[]
  products       Product[]
  contacts       Contact[]
  warehouses     Warehouse[]
  taxes          TenantTax[]
  tickets        Ticket[]
  refunds        Refund[]
  syncOutbox     SyncOutbox[]
  holdedUploads  HoldedUpload[]
  modifierGroups ModifierGroup[]
  tagAliases     TagAlias[]

  @@map("tenants")
}

// v1.3-Operativa-Extra Lote 1 · mapeo "slug Holded → label TPV" editable
// por OWNER/MANAGER. El TPV consulta este mapa al renderizar los chips
// de categoría: si encuentra una entrada para el tag (en lowercase
// como llega de Holded) usa el `label`, si no cae al `capitalizeTag`
// del hotfix5. Permite que el cliente renombre "01cortesypeinados" →
// "Cortes y peinados" sin tocar los productos en Holded.
model TagAlias {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  slug      String   @db.VarChar(60)
  label     String   @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@map("tag_aliases")
}

// Tipos de IVA del catálogo Holded del tenant. Spike §03.A: array de 103
// elementos en sandbox, indexamos por holded_tax_id (string tipo
// "s_iva_21") y por rate numérico. Permite mapeo bidireccional al
// construir el payload de líneas.
model TenantTax {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  holdedTaxId String   @map("holded_tax_id")
  rate        Decimal? @db.Decimal(5, 2)
  name        String?
  raw         Json?
  syncedAt    DateTime @default(now()) @map("synced_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, holdedTaxId])
  @@index([tenantId, rate])
  @@map("tenant_taxes")
}

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  email                  String    @unique
  passwordHash           String?   @map("password_hash")
  // PIN sólo lo tienen cajeros/encargados que tocan el TPV físico.
  pinHash                String?   @map("pin_hash")
  role                   UserRole
  // Incrementa con `POST /auth/logout-everywhere` (B2 §4.3). Los
  // refresh tokens llevan este `tv` en su payload; si no coincide con
  // el de BD, el refresh se rechaza. Permite invalidación masiva sin
  // mantener una blacklist por jti.
  tokenVersion           Int       @default(0) @map("token_version")
  // 2FA TOTP (§17.3). Secret AES-GCM versionado (`v1:` prefix) con la
  // misma clave que la API key Holded. `twoFactorEnabledAt` actúa como
  // flag y timestamp: NULL → 2FA off; valor → on.
  twoFactorSecret        String?   @map("two_factor_secret")
  twoFactorEnabledAt     DateTime? @map("two_factor_enabled_at") @db.Timestamptz()
  // Array JSON de objetos `{ hash: <argon2id>, usedAt: ISO|null }`.
  // Códigos de un solo uso; cuando se usa uno se marca `usedAt` (no se
  // borra para que el contador del admin pueda mostrar "X/10 sin
  // usar").
  twoFactorRecoveryCodes Json?     @map("two_factor_recovery_codes")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastLoginAt            DateTime? @map("last_login_at") @db.Timestamptz()
  // B-SuperAdmin: cuando un super-admin crea un OWNER, su password
  // temporal viene marcada con must_change_password_at = now(). El
  // siguiente login redirige obligatoriamente a /change-password-initial.
  // Al cambiarla se pone a NULL y se incrementa tokenVersion.
  mustChangePasswordAt   DateTime? @map("must_change_password_at") @db.Timestamptz()
  // B-OnboardingV2: marca el cajero técnico que el equipo mipiacetpv usa
  // para probar el TPV antes de que el cliente toque nada. El worker
  // `ticket-upload-worker` mira este flag (a través de `ticket.user`)
  // para NO subir el ticket a Holded; el worker de email lo skipea para
  // no mandar correos a clientes reales. Al activar el tenant
  // (POST /super-admin/tenants/:id/activate), los tickets TEST se
  // borran y este user queda soft-deleted (deletedAt poblado abajo).
  isTestCashier          Boolean   @default(false) @map("is_test_cashier")
  // B-OnboardingV2: soft-delete del cajero técnico tras activar el
  // tenant. Permite conservar histórico ligero sin que la UI lo liste.
  // Sólo se aplica a usuarios `isTestCashier=true`; los OWNER/MANAGER/
  // CASHIER reales se bloquean vía `Tenant.blockedAt` o
  // `User.tokenVersion`. No se reutiliza para borrado de usuarios reales.
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz()

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts         Shift[]              @relation("ShiftOpenedBy")
  closedShifts   Shift[]              @relation("ShiftClosedBy")
  tickets        Ticket[]
  pairingCodes   PairingCode[]
  resetTokens    PasswordResetToken[]
  refunds        Refund[]
  emailJobsAsked TicketEmailJob[]
  printIntents   PrintIntent[]

  @@index([tenantId])
  @@map("users")
}

model Store {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  name              String
  fiscalAddress     Json?     @map("fiscal_address")
  warehouseHoldedId String?   @map("warehouse_holded_id")
  // Config de entrega del ticket digital (B-Print fase 1):
  //   {
  //     emailAutoIfCustomerHasEmail: boolean,
  //     showQrButton: boolean,
  //     showDownloadButton: boolean,
  //     showViewButton: boolean,
  //     emailSubject: string,
  //     emailBody: string,
  //     qrCaption: string
  //   }
  // Defaults sensatos al crear (todo true, plantillas ES). El TPV lo
  // lee al cobrar para mostrar los botones correctos en post-cobro.
  ticketDelivery    Json?     @map("ticket_delivery")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  // Soft-delete (B4 §0.2). Las FKs a Register/Shift/Ticket son Restrict
  // — borrar duro rompería histórico fiscal. `deletedAt != null` saca la
  // tienda del listado pero preserva todo lo demás.
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz()

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registers Register[]
  tables    Table[]

  @@index([tenantId])
  @@map("stores")
}

// Mesa lógica del vertical bar/hostelería (B7). El estado (libre /
// ocupada / cobrando) NO se persiste — se deriva en runtime de la
// presencia de un `Ticket` con `status=DRAFT` apuntando a esta mesa.
model Table {
  id                 String    @id @default(uuid()) @db.Uuid
  storeId            String    @map("store_id") @db.Uuid
  name               String
  capacity           Int       @default(2)
  zone               TableZone @default(SALON)
  // Posición opcional en el canvas del admin. Si todas son NULL, el
  // TPV renderiza la zona en grid auto. El canvas drag-and-drop se
  // difiere a un evolutivo; el schema queda preparado.
  positionX          Int?      @map("position_x")
  positionY          Int?      @map("position_y")
  width              Int?
  height             Int?
  // Para zona BARRA: orden del puesto dentro de la barra (B1=1,
  // B2=2, ...). Permite renderizar la barra como array de mini-mesas.
  // NULL fuera de la zona BARRA.
  barSeatIndex       Int?      @map("bar_seat_index")
  // Si esta mesa ha sido absorbida por otra dentro de un grupo (§5.2
  // del prompt B7), apunta a la mesa principal. NULL = mesa autónoma.
  // Se limpia automáticamente al cobrar el ticket principal del grupo.
  groupedIntoTableId String?   @map("grouped_into_table_id") @db.Uuid
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz()
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tickets        Ticket[]
  groupedInto    Table?   @relation("TableGrouping", fields: [groupedIntoTableId], references: [id])
  absorbedTables Table[]  @relation("TableGrouping")

  @@unique([storeId, name])
  @@index([storeId, zone])
  @@index([groupedIntoTableId])
  @@map("tables")
}

// Caja LÓGICA. Un punto de venta dentro de una tienda. No es un
// dispositivo: para vender necesita además uno o más `device`
// emparejados (§3.2).
model Register {
  id             String    @id @default(uuid()) @db.Uuid
  storeId        String    @map("store_id") @db.Uuid
  name           String
  // Serie Holded para los salesreceipt de esta caja. Permite numeración
  // fiscal separada por caja. Nullable: puede crearse sin asignarla y
  // configurarla después.
  numSerieHolded String?   @map("num_serie_holded")
  ticketCounter  Int       @default(0) @map("ticket_counter")
  printerConfig  Json?     @map("printer_config")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  // Soft-delete (B4 §0.2). Igual que Store.
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz()

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  devices      Device[]
  pairingCodes PairingCode[]
  shifts       Shift[]
  tickets      Ticket[]
  refunds      Refund[]

  @@index([storeId])
  @@map("registers")
}

// Navegador físico emparejado a una caja. El token de larga duración
// vive en localStorage del navegador; aquí guardamos sólo su hash.
model Device {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  registerId         String    @map("register_id") @db.Uuid
  name               String?
  pairedAt           DateTime  @default(now()) @map("paired_at") @db.Timestamptz()
  lastSeenAt         DateTime? @map("last_seen_at") @db.Timestamptz()
  userAgent          String?   @map("user_agent")
  deviceTokenHash    String    @unique @map("device_token_hash")
  // Si está revocado, la PWA detecta el rechazo y vuelve a la pantalla
  // de emparejamiento.
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz()
  // ISO 3166-1 alfa-2 del país de la última IP vista (geoip-lite). Se
  // usa para detectar saltos de país y disparar alerta email (§17.4).
  lastKnownIpCountry String?   @map("last_known_ip_country")
  // Timestamp del último email de alerta enviado para este device. Sirve
  // de antispam — si la IP fluctúa de provincia no se reenvía. Sólo se
  // dispara primer login, cambio de país y re-aparición tras 30d.
  lastEmailAlertAt   DateTime? @map("last_email_alert_at") @db.Timestamptz()

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  register         Register      @relation(fields: [registerId], references: [id], onDelete: Cascade)
  consumedPairings PairingCode[] @relation("PairingCodeConsumedBy")

  @@index([tenantId])
  @@index([registerId])
  @@map("devices")
}

// Código efímero que el propietario/encargado entrega al dispositivo
// nuevo. 6 dígitos; vida útil típica 1h. Unique compound (tenantId,
// code) para evitar colisiones del RNG dentro del mismo tenant.
model PairingCode {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  registerId         String    @map("register_id") @db.Uuid
  code               String
  createdByUserId    String    @map("created_by_user_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  expiresAt          DateTime  @map("expires_at") @db.Timestamptz()
  consumedAt         DateTime? @map("consumed_at") @db.Timestamptz()
  consumedByDeviceId String?   @map("consumed_by_device_id") @db.Uuid

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  register         Register @relation(fields: [registerId], references: [id], onDelete: Cascade)
  createdBy        User     @relation(fields: [createdByUserId], references: [id])
  consumedByDevice Device?  @relation("PairingCodeConsumedBy", fields: [consumedByDeviceId], references: [id])

  @@unique([tenantId, code])
  @@index([registerId])
  @@index([expiresAt])
  @@map("pairing_codes")
}

// ── Catálogo (cache local de Holded) ──────────────────────────────────

model Product {
  id                String      @id @default(uuid()) @db.Uuid
  tenantId          String      @map("tenant_id") @db.Uuid
  holdedProductId   String      @map("holded_product_id")
  name              String
  sku               String?
  barcode           String?
  basePrice         Decimal     @map("base_price") @db.Decimal(10, 2)
  taxRate           Decimal     @map("tax_rate") @db.Decimal(5, 2)
  kind              ProductKind @default(PRODUCT)
  active            Boolean     @default(true)
  // True si el SKU lo asignó el script auto-SKU (patrón AUTO-<8>).
  // Permite distinguirlos del SKU manual del propietario.
  skuAutoAssignedAt DateTime?   @map("sku_auto_assigned_at") @db.Timestamptz()
  // True si el auto-SKU envió el PUT pero el GET-back demostró que
  // Holded silenció el cambio (ADR-010). Sale en la bandeja de
  // revisión del admin. El producto NO es vendible hasta resolverlo.
  needsSkuReview    Boolean     @default(false) @map("needs_sku_review")
  // Contador de intentos de asignar SKU vía la bandeja (POST
  // /catalog/sku-review/:id/assign). Se incrementa tanto en éxito como
  // en silent reject — sirve para mostrar el contador "ha fallado N
  // veces" en el admin y para escalar a soporte (badge ámbar ≥3).
  skuReviewAttempts Int         @default(0) @map("sku_review_attempts")
  // True si el TPV puede vender este ítem (sku no vacío y bajos
  // demás filtros). Spike §07.B: producto sin sku → línea inválida.
  sellableViaTpv    Boolean     @default(true) @map("sellable_via_tpv")
  // B-ProductImages: URL canónica de la imagen del producto tal como la
  // expone Holded (campo identificado en spike §13). NULL si el producto
  // no tiene imagen en Holded → el TPV cae al placeholder embebido. El
  // worker `image-cache-worker` descarga la imagen y la sirve cacheada
  // desde Caddy en `/product-images/<tenantId>/<productId>.<ext>`.
  imageUrl          String?     @map("image_url")
  // MIME del binario una vez descargado y validado por el worker
  // (`image/jpeg`, `image/png`, `image/webp`). NULL hasta que el worker
  // confirme una descarga válida; el TPV usa este campo como gate para
  // renderizar `<img>` vs. placeholder.
  imageMime         String?     @map("image_mime")
  // Cuándo el worker guardó por última vez el archivo en disco. Si la
  // URL cambia en un sync (Holded la rota), el sync pone `imageCachedAt
  // = null` para forzar re-descarga; el worker la detecta como pendiente.
  imageCachedAt     DateTime?   @map("image_cached_at") @db.Timestamptz()
  // B-Categorias-via-Tags: tags libres que el propietario asigna a
  // sus productos en Holded (campo `tags: string[]` en el payload de
  // /products). El TPV los usa como pseudo-categorías para construir
  // los chips de filtro arriba de la grid de productos. Si Holded no
  // envía tags, queda como array vacío. Tiene índice GIN
  // (products_tags_idx) para futuros filtros server-side @> y &&.
  tags              String[]    @default([])
  lastSyncedAt      DateTime    @default(now()) @map("last_synced_at") @db.Timestamptz()
  raw               Json?

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants       ProductVariant[]
  lines          TicketLine[]
  modifierGroups ProductModifierGroup[]

  @@unique([tenantId, holdedProductId])
  @@index([tenantId, barcode])
  @@index([tenantId, sku])
  @@index([tenantId, needsSkuReview])
  @@map("products")
}

model ProductVariant {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  holdedVariantId String?  @map("holded_variant_id")
  name            String
  sku             String?
  barcode         String?
  priceOverride   Decimal? @map("price_override") @db.Decimal(10, 2)
  stock           Int      @default(0)

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  lines   TicketLine[]

  @@index([productId])
  @@index([barcode])
  @@map("product_variants")
}

model Warehouse {
  id                String @id @default(uuid()) @db.Uuid
  tenantId          String @map("tenant_id") @db.Uuid
  holdedWarehouseId String @map("holded_warehouse_id")
  name              String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, holdedWarehouseId])
  @@map("warehouses")
}

// Cache local de contactos de Holded. A diferencia de Product, NO hay
// sync inicial completo (B2 §3): los contactos del tenant pueden ser
// miles. El endpoint `GET /contacts/search` busca primero aquí; si no
// encuentra resultados, llama a Holded en vivo y upserta. El endpoint
// `POST /contacts` crea contacto on-the-fly desde el TPV con GET-back.
model Contact {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  holdedContactId  String    @map("holded_contact_id")
  name             String
  nif              String?
  email            String?
  phone            String?
  raw              Json?
  // Si false, el contacto fue marcado como huérfano en el último sync
  // incremental (B7 §8): ya no existe en Holded. Lo conservamos por si
  // hay tickets históricos que apuntan a él. La UI del TPV lo oculta.
  active           Boolean   @default(true)
  // Marca temporal del último sync que vio este contacto en Holded.
  // El cron incremental marca `active=false` cuando NOT seen >24h.
  lastSeenInSyncAt DateTime? @map("last_seen_in_sync_at") @db.Timestamptz()
  lastSyncedAt     DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, holdedContactId])
  @@index([tenantId, email])
  @@index([tenantId, nif])
  @@index([tenantId, name])
  @@map("contacts")
}

// ── Operativa de ventas ───────────────────────────────────────────────

model Shift {
  id             String    @id @default(uuid()) @db.Uuid
  registerId     String    @map("register_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  openedAt       DateTime  @default(now()) @map("opened_at") @db.Timestamptz()
  closedAt       DateTime? @map("closed_at") @db.Timestamptz()
  // Última actividad observada en el turno. Se actualiza a `now()` en
  // cada cobro y al hacer cashier-login con `reanudar`. Sirve para
  // diferenciar "turno reanudable" (mismo día) de "turno colgado" (día
  // anterior) en la lógica de login (§4 nucleus).
  lastActivityAt DateTime  @default(now()) @map("last_activity_at") @db.Timestamptz()
  cashOpening    Decimal   @map("cash_opening") @db.Decimal(10, 2)
  cashCounted    Decimal?  @map("cash_counted") @db.Decimal(10, 2)
  // Quién ejecutó el cierre. Puede ser distinto al `userId` cuando un
  // cajero cierra un turno colgado de un compañero (§3.5 del prompt).
  closedByUserId String?   @map("closed_by_user_id") @db.Uuid
  zReportPdfPath String?   @map("z_report_pdf_path")

  register   Register         @relation(fields: [registerId], references: [id], onDelete: Restrict)
  user       User             @relation("ShiftOpenedBy", fields: [userId], references: [id], onDelete: Restrict)
  closedBy   User?            @relation("ShiftClosedBy", fields: [closedByUserId], references: [id], onDelete: Restrict)
  tickets    Ticket[]
  refunds    Refund[]
  cashCounts ShiftCashCount[]

  @@index([registerId, openedAt])
  @@index([registerId, closedAt])
  @@map("shifts")
}

// v1.3-Thalia Lote 4 · arqueo por denominaciones. Cada fila representa
// un conteo puntual de caja: X (intermedio, no cierra) o Z (cierre del
// turno). El backend es el único que calcula `cashTotal` desde el JSON
// de denominaciones — el cliente no se cree (auditoría fiscal). El JSON
// usa strings como llave ("500", "0.01") por compatibilidad JSON; el
// backend interpreta cada llave como euros.
model ShiftCashCount {
  id            String             @id @default(uuid()) @db.Uuid
  shiftId       String             @map("shift_id") @db.Uuid
  shift         Shift              @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  kind          ShiftCashCountKind
  // {"500":0,"200":0,...,"0.01":5} — el server vuelve a calcular el total.
  denominations Json
  cashTotal     Decimal            @map("cash_total") @db.Decimal(12, 2)
  // Quién hizo el arqueo. Distinto al `userId` del shift cuando un
  // encargado pasa por la caja a hacer un X de control.
  createdByUserId String           @map("created_by_user_id") @db.Uuid
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz()

  @@index([shiftId, createdAt])
  @@map("shift_cash_counts")
}

model Ticket {
  id                   String       @id @default(uuid()) @db.Uuid
  tenantId             String       @map("tenant_id") @db.Uuid
  registerId           String       @map("register_id") @db.Uuid
  shiftId              String       @map("shift_id") @db.Uuid
  userId               String       @map("user_id") @db.Uuid
  internalNumber       String       @map("internal_number")
  // UUID v4 generado en el front al cobrar. Llave de idempotencia hacia
  // Holded. Nunca se regenera.
  externalId           String       @unique @map("external_id") @db.Uuid
  // Capability slug público (16 hex = 8 bytes random ≈ 96 bits) que
  // alimenta el QR, el email y el botón "Ver ticket". Permite al
  // cliente final descargar el PDF sin auth — la entropía es el secreto.
  // B-Print fase 1.
  publicSlug           String       @unique @map("public_slug")
  // Timestamp del último fallo persistente del email auto-enviado.
  // El bandeja admin lo muestra para que el propietario sepa que el
  // cliente no recibió su ticket pese a que la sync con Holded fue OK.
  emailFailedAt        DateTime?    @map("email_failed_at") @db.Timestamptz()
  contactHoldedId      String?      @map("contact_holded_id")
  status               TicketStatus @default(DRAFT)
  total                Decimal      @db.Decimal(10, 2)
  totalTax             Decimal      @map("total_tax") @db.Decimal(10, 2)
  totalDiscount        Decimal      @map("total_discount") @db.Decimal(10, 2)
  // Texto libre de la venta. Se imprime en el ticket y se concatena a
  // las `notes` Holded después del marcador `TPV-uuid:` (§1.3).
  notes                String?
  // Efectivo recibido (para cálculo de cambio en histórico). Nullable
  // si no hubo efectivo en el cobro.
  cashAmount           Decimal?     @map("cash_amount") @db.Decimal(10, 2)
  holdedDocumentId     String?      @map("holded_document_id")
  // Numeración fiscal asignada por Holded tras el `approveDoc:true`.
  // Cara visible al cliente; se imprime en el ticket cuando llega.
  holdedDocNumber      String?      @map("holded_doc_number")
  holdedPdfUrl         String?      @map("holded_pdf_url")
  // Intents post-cobro. La impresión real es B5; en B4 sólo persistimos
  // la decisión del cajero.
  printIntent          Boolean      @default(true) @map("print_intent")
  emailIntent          String?      @map("email_intent")
  // Timestamp del momento en que el cajero pulsa "Imprimir ticket
  // regalo" (§5.2). Nullable; sólo se rellena si se solicitó.
  giftReceiptIntentAt  DateTime?    @map("gift_receipt_intent_at") @db.Timestamptz()
  // Email del MANAGER que autorizó este ticket con descuento superior
  // al umbral (B6 §2). Sólo se rellena si el descuento efectivo del
  // ticket supera `tenant.discountThresholdPct`. NULL en el caso normal.
  discountAuthorizedBy String?      @map("discount_authorized_by")
  // Mesa abierta a la que pertenece este ticket (B7). NULL para tickets
  // de venta rápida (retail). El estado de la mesa se deriva: si existe
  // un ticket con `tableId=X, status=DRAFT` la mesa X está ocupada.
  tableId              String?      @map("table_id") @db.Uuid
  table                Table?       @relation(fields: [tableId], references: [id])
  // Si este ticket nació como absorción de otra mesa en un grupo (§5),
  // se conserva el origen para histórico.
  originalTableId      String?      @map("original_table_id") @db.Uuid
  // Nº de comensales introducido al abrir la mesa. Informativo (no
  // bloquea capacidad).
  diners               Int?
  // v1.3-Servicios-Pinta · Lote 3: nombre del profesional que atendió
  // (peluquería/clínica/taller). Texto libre opcional introducido en
  // checkout. Vacío en RETAIL/HOSPITALITY. Se imprime en el ticket
  // entre cabecera y líneas si el tenant es SERVICES.
  attendedBy           String?      @map("attended_by") @db.VarChar(60)
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  paidAt               DateTime?    @map("paid_at") @db.Timestamptz()
  syncedAt             DateTime?    @map("synced_at") @db.Timestamptz()
  syncError            Json?        @map("sync_error")

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  register     Register         @relation(fields: [registerId], references: [id], onDelete: Restrict)
  shift        Shift            @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  user         User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  lines        TicketLine[]
  payments     TicketPayment[]
  refunds      Refund[]
  emailJobs    TicketEmailJob[]
  printIntents PrintIntent[]

  @@unique([registerId, internalNumber])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([registerId, createdAt])
  @@index([shiftId])
  @@index([externalId])
  @@index([tableId, status])
  @@map("tickets")
}

model TicketLine {
  id              String  @id @default(uuid()) @db.Uuid
  ticketId        String  @map("ticket_id") @db.Uuid
  productId       String? @map("product_id") @db.Uuid
  variantId       String? @map("variant_id") @db.Uuid
  // Snapshot del `holdedProductId` del catálogo en el momento del cobro.
  // El worker NO toca `Product` para construir el payload: lee el
  // snapshot de aquí, así si Holded ha borrado el producto entre cobro
  // y envío al menos sabemos qué intentó vender. Nullable para líneas
  // libres (TPV-OTROS-*).
  holdedProductId String? @map("holded_product_id")
  // SKU canónico que se envía a Holded en el item. Spike §05.B: es la
  // llave de resolución del producto. NUNCA enviar productId aquí.
  sku             String
  // Copia del nombre en el momento del cobro: cambiar el producto en
  // Holded no debe alterar tickets históricos.
  nameSnapshot    String  @map("name_snapshot")
  units           Decimal @db.Decimal(10, 3)
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)
  // v1.2-Lite Lote 4.B · T-5: si el cajero modifica el precio puntualmente
  // (libro descatalogado, ajuste rápido) se guarda aquí. NULL = sin
  // override, se cobra el `unitPrice` base. Cuando hay override, los
  // cálculos de subtotal/total usan este valor; el `unitPrice` queda
  // como histórico del catálogo para que la auditoría pueda mostrar
  // "modificado de X€ a Y€". Holded recibe el override (acepta precios
  // unitarios distintos del producto base).
  unitPriceOverride Decimal? @map("unit_price_override") @db.Decimal(10, 2)
  discountPct     Decimal @default(0) @map("discount_pct") @db.Decimal(5, 2)
  taxRate         Decimal @map("tax_rate") @db.Decimal(5, 2)
  subtotal        Decimal @db.Decimal(10, 2)
  total           Decimal @db.Decimal(10, 2)
  // Snapshot inmutable de modificadores aplicados al cobrar
  // (B-Bar-Modifiers). Dos shapes históricos soportados por el
  // renderer del TPV — ambos viven en este Json?:
  //   1. Legacy (pre-B-Bar-Modifiers): `string[]` ad-hoc tipeado por
  //      el cajero ("Sin azúcar", "Sin postre"). No tiene precio ni
  //      grupo. Se conserva por compatibilidad de tickets históricos
  //      y porque el "modificador rápido tipeado" sigue siendo útil
  //      en barras pequeñas.
  //   2. Estructurado (post-B-Bar-Modifiers): array de objetos
  //      `{ groupId, groupName, modifierId, label, priceDeltaCents }`.
  //      Producido por el modal <ModifierSelector> a partir de los
  //      ModifierGroup/Modifier del catálogo. Desnormalizado a propósito:
  //      cambios futuros en el catálogo no alteran el ticket histórico
  //      (auditoría fiscal inmutable).
  //
  // El cálculo del subtotal de la línea ya incluye los priceDeltas
  // antes de persistir — `unitPrice` no se modifica, los deltas viven
  // sólo en este snapshot. Lo que se envía a Holded es el precio
  // rolled-up + el desglose textual en `description`/`notes` del item.
  modifiers       Json?
  // Si esta línea proviene de otra mesa (mover líneas o agrupar),
  // queda registrado el origen. Permite desagrupar reversiblemente
  // (B7 §5.3).
  originalTableId String? @map("original_table_id") @db.Uuid

  ticket      Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  refundLines RefundLine[]

  @@index([ticketId])
  @@map("ticket_lines")
}

model TicketPayment {
  id       String        @id @default(uuid()) @db.Uuid
  ticketId String        @map("ticket_id") @db.Uuid
  method   PaymentMethod
  amount   Decimal       @db.Decimal(10, 2)
  meta     Json?

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_payments")
}

model Refund {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  originalTicketId String         @map("original_ticket_id") @db.Uuid
  userId           String?        @map("user_id") @db.Uuid
  registerId       String?        @map("register_id") @db.Uuid
  shiftId          String?        @map("shift_id") @db.Uuid
  internalNumber   String         @map("internal_number")
  externalId       String         @unique @map("external_id") @db.Uuid
  status           TicketStatus   @default(DRAFT)
  reason           String?
  // Método de reembolso (por defecto, el mismo del cobro original).
  method           PaymentMethod?
  // Snapshot del total devuelto (con IVA). Se calcula sumando las
  // refund_lines. Se persiste explícito para que el worker no necesite
  // re-calcular ni el front re-pedir las líneas para listar.
  total            Decimal        @db.Decimal(10, 2)
  totalTax         Decimal        @map("total_tax") @db.Decimal(10, 2)
  holdedDocumentId String?        @map("holded_document_id")
  holdedDocNumber  String?        @map("holded_doc_number")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  syncedAt         DateTime?      @map("synced_at") @db.Timestamptz()
  syncError        Json?          @map("sync_error")

  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  originalTicket Ticket       @relation(fields: [originalTicketId], references: [id], onDelete: Restrict)
  user           User?        @relation(fields: [userId], references: [id], onDelete: Restrict)
  register       Register?    @relation(fields: [registerId], references: [id], onDelete: Restrict)
  shift          Shift?       @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  lines          RefundLine[]

  @@index([originalTicketId])
  @@index([tenantId, status])
  @@map("refunds")
}

model RefundLine {
  id           String  @id @default(uuid()) @db.Uuid
  refundId     String  @map("refund_id") @db.Uuid
  ticketLineId String  @map("ticket_line_id") @db.Uuid
  // Snapshot del nombre/sku/precio de la línea original. El worker
  // construye el payload con estos valores; si la línea original
  // cambia o el producto desaparece de Holded, la devolución
  // sigue siendo reproducible.
  nameSnapshot String  @map("name_snapshot")
  sku          String
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  taxRate      Decimal @map("tax_rate") @db.Decimal(5, 2)
  discountPct  Decimal @default(0) @map("discount_pct") @db.Decimal(5, 2)
  units        Decimal @db.Decimal(10, 3)
  total        Decimal @db.Decimal(10, 2)

  refund     Refund     @relation(fields: [refundId], references: [id], onDelete: Cascade)
  ticketLine TicketLine @relation(fields: [ticketLineId], references: [id], onDelete: Restrict)

  @@index([refundId])
  @@map("refund_lines")
}

// ── Cola de sync (espejo en BD por si Redis se cae) ───────────────────

model SyncOutbox {
  id            BigInt           @id @default(autoincrement())
  tenantId      String           @map("tenant_id") @db.Uuid
  kind          SyncOutboxKind
  payload       Json
  attempts      Int              @default(0)
  nextAttemptAt DateTime         @default(now()) @map("next_attempt_at") @db.Timestamptz()
  lastError     Json?            @map("last_error")
  status        SyncOutboxStatus @default(PENDING)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([tenantId, status])
  @@map("sync_outbox")
}

// Idempotencia de subidas a Holded (spike §04.F). Holded NO deduplica
// por contenido de `notes` y NO expone búsqueda por externalId — toda
// la idempotencia vive aquí. Antes de POSTear el doc, el worker
// consulta esta tabla por externalId; si ya hay holded_document_id,
// no reintenta.
model HoldedUpload {
  externalId       String             @id @map("external_id") @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  kind             HoldedUploadKind
  holdedDocumentId String?            @map("holded_document_id")
  attempts         Int                @default(0)
  lastAttemptAt    DateTime?          @map("last_attempt_at") @db.Timestamptz()
  status           HoldedUploadStatus @default(PENDING)
  lastError        Json?              @map("last_error")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("holded_uploads")
}

// Cola de envío del PDF del ticket por email (§4 del prompt B4).
// El endpoint `POST /tickets/:id/resend-email` crea una fila y encola
// un job BullMQ; el worker descarga el PDF de Holded (cuando el ticket
// esté `SYNCED`), lo manda al `to_email` y marca `sent_at`. Reintento
// exponencial; ante fallo persistente, queda `status=FAILED` con
// `last_error` poblado.
model TicketEmailJob {
  id                String    @id @default(uuid()) @db.Uuid
  ticketId          String    @map("ticket_id") @db.Uuid
  toEmail           String    @map("to_email")
  requestedByUserId String    @map("requested_by_user_id") @db.Uuid
  attempts          Int       @default(0)
  lastError         Json?     @map("last_error")
  // PENDING | DONE | FAILED. String libre — sin enum porque va a la cola
  // BullMQ y se desacopla del ciclo de Prisma migrate.
  status            String    @default("PENDING")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  sentAt            DateTime? @map("sent_at") @db.Timestamptz()

  ticket          Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  requestedByUser User   @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@index([status])
  @@map("ticket_email_jobs")
}

// Token de recuperación de contraseña del propietario (§17.6). El token
// plano se envía sólo por email; en BD guardamos sólo su hash argon2id.
// TTL 1h, un solo uso. La revocación masiva al confirmar el reset se
// hace vía `user.tokenVersion += 1`.
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ── Modificadores de producto (B-Bar-Modifiers) ────────────────────────
//
// Caso B confirmado (spike §14): Holded no expone modificadores
// nativamente. El CRUD vive entera en mipiacetpv y es per-tenant. El
// cajero los selecciona en el modal <ModifierSelector> al añadir una
// línea del producto; el snapshot inmutable acaba en `TicketLine.modifiers`.
// A Holded llega un precio "rolled up" + desglose textual en la
// description del item — Holded sólo ve el precio total y la nota.

model ModifierGroup {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Nombre del grupo visible al cajero ("Tipo de leche", "Tamaño").
  name      String
  // Si true, sólo se puede seleccionar 1 modifier del grupo (radio).
  // Si false, se pueden seleccionar varios (checkbox). Default true.
  exclusive Boolean  @default(true)
  // Si true, es obligatorio seleccionar al menos un modifier antes
  // de añadir la línea. Útil para "Tamaño" donde no hay default.
  required  Boolean  @default(false)
  // Orden de presentación en el modal del TPV (asc).
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  // Soft-delete para preservar histórico de TicketLine.modifiers que
  // referencian este groupId tras quitar la variante del menú.
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  modifiers Modifier[]
  products  ProductModifierGroup[]

  @@index([tenantId, deletedAt])
  @@map("modifier_groups")
}

model Modifier {
  id              String        @id @default(uuid()) @db.Uuid
  modifierGroupId String        @map("modifier_group_id") @db.Uuid
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  // Etiqueta visible ("Sin leche", "Con leche desnatada", "Grande").
  label           String
  // Suplemento o descuento al precio del producto. Puede ser
  // negativo (descuento) o cero (sin coste). En céntimos para evitar
  // floats, igual que el resto del modelo (Decimal del producto se
  // convierte a céntimos en runtime).
  priceDeltaCents Int           @default(0) @map("price_delta_cents")
  sortOrder       Int           @default(0) @map("sort_order")
  // Si true, este modifier está pre-seleccionado al abrir el grupo.
  // Sólo tiene efecto en grupos exclusive=true.
  isDefault       Boolean       @default(false) @map("is_default")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  // Soft-delete (mismo motivo que ModifierGroup.deletedAt).
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz()

  @@index([modifierGroupId, deletedAt])
  @@map("modifiers")
}

// Tabla puente N:N entre productos y grupos de modificadores. Un grupo
// puede aplicar a varios productos ("Tipo de leche" sirve para café,
// té, chocolate) y un producto puede tener varios grupos ("Café" tiene
// "Tipo de leche" + "Tamaño" + "Azúcar"). El borrado del producto o
// del grupo elimina la fila puente sin tocar al otro lado.
model ProductModifierGroup {
  productId       String        @map("product_id") @db.Uuid
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroupId String        @map("modifier_group_id") @db.Uuid
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  sortOrder       Int           @default(0) @map("sort_order")

  @@id([productId, modifierGroupId])
  @@index([modifierGroupId])
  @@map("product_modifier_groups")
}

// ── Super-admin (B-SuperAdmin) ────────────────────────────────────────
//
// Identidad ortogonal a `User` (per-tenant). Razón: que un User
// escalable nunca pueda derivar en permisos super. Aislamiento limpio.
// El alta se hace exclusivamente vía CLI seed
// (`apps/api/src/scripts/create-super-admin.ts`) — no hay UI para
// invitar nuevos super-admins. Decisión defensiva.

model SuperAdminUser {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  // B-Multi-Vertical SB4: nombre legible mostrado en el panel de
  // gestión multi-admin. Nullable porque el super-admin original
  // (Matías, creado vía CLI seed) no tenía nombre — backfill rellena
  // con split_part(email, '@', 1).
  name            String?   @db.VarChar(100)
  passwordHash    String    @map("password_hash")
  // Igual que User.tokenVersion: logout-everywhere lo bumpea, los
  // refresh tokens viejos pasan a ser inválidos sin tabla blacklist.
  tokenVersion    Int       @default(0) @map("token_version")
  // 2FA TOTP. Mismo patrón cifrado AES-GCM (`v1:`) que User.
  totpSecret      String?   @map("totp_secret")
  totpEnabledAt   DateTime? @map("totp_enabled_at") @db.Timestamptz()
  // Array de `{ hash, usedAt }` (mismo shape que User.twoFactorRecoveryCodes).
  recoveryCodes   Json?     @map("recovery_codes")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz()
  // B-Multi-Vertical SB4: super-admin invitado por otro super-admin
  // empieza con password temporal. true → al primer login el front le
  // pide cambiarla. Se pone false en cuanto se cambia.
  mustChangePassword Boolean @default(false) @map("must_change_password")
  // Lote 3 v1.1 Thalia: sólo el "root" puede invitar/eliminar a otros
  // super-admins. El resto opera tenants y nada más. El middleware
  // requireRootSuperAdmin re-lee este flag de BD en cada request — el
  // claim JWT NO es autoritativo (revoca-root tras emisión de token
  // funciona en la siguiente request).
  isRoot          Boolean   @default(false) @map("is_root")
  // B-Multi-Vertical SB4: soft-delete. Preservamos el row para que la
  // tabla `super_admin_audits` (que tiene FK Restrict sobre este
  // modelo) mantenga el histórico aunque se "borre" al super-admin.
  // El listado y la auth filtran por deletedAt IS NULL.
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  audits SuperAdminAudit[]

  @@map("super_admin_users")
}

// v1.3-Thalia Lote 3 · cola de intents de impresión. Cada fila
// representa una orden que el bridge B5 (PWA del navegador o servicio
// nativo) consume para mandar al hardware. El renderer del PDF puede
// pintar marcas distintas según `kind` (p.ej. "COPIA — no fiscal"
// para REPRINT) — la lógica vive en `ticket-pdf`, este modelo sólo
// guarda el intent.
model PrintIntent {
  id                String          @id @default(uuid()) @db.Uuid
  ticketId          String          @map("ticket_id") @db.Uuid
  ticket            Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  kind              PrintIntentKind
  // PENDING al crear; el bridge lo marca DONE tras imprimir o FAILED
  // si la impresora rechazó. String libre — sin enum porque viaja a
  // BullMQ y se desacopla del ciclo Prisma migrate.
  status            String          @default("PENDING")
  // Quién lo solicitó. NEW lo crea el handler de cobro (es el cajero
  // del shift); REPRINT lo crea el cajero que abre el historial; GIFT
  // lo crea el cajero del cobro original. Útil para auditoría.
  requestedByUserId String          @map("requested_by_user_id") @db.Uuid
  requestedBy       User            @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  pickedAt          DateTime?       @map("picked_at") @db.Timestamptz()
  doneAt            DateTime?       @map("done_at") @db.Timestamptz()
  lastError         String?         @map("last_error")

  @@index([status, createdAt])
  @@index([ticketId, kind, createdAt])
  @@map("print_intents")
}

// Auditoría inmutable de toda acción super-admin. Sin retención
// automática — se conserva indefinidamente para histórico.
model SuperAdminAudit {
  id           String         @id @default(uuid()) @db.Uuid
  superAdminId String         @map("super_admin_id") @db.Uuid
  superAdmin   SuperAdminUser @relation(fields: [superAdminId], references: [id], onDelete: Restrict)
  // "create_tenant" | "update_tenant" | "block_tenant" | "unblock_tenant"
  // | "force_logout" | "resync" | "impersonate". Validado con zod en la
  // capa de servicio antes de persistir.
  action       String
  tenantId     String?        @map("tenant_id") @db.Uuid
  // Shape estricto por acción (ver docs/blocks/B-SuperAdmin-done.md).
  // Siempre incluye `ipAddress` y `userAgent`.
  metadata     Json?
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  @@index([superAdminId, createdAt])
  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@map("super_admin_audits")
}
