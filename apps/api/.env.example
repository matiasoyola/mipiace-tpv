# Copia este archivo a `.env` y rellena los valores.
# El `.env` real está en .gitignore.

# API Key de Holded. Header HTTP literal: `key: <valor>`.
HOLDED_API_KEY=

# URL base de la API de Holded.
HOLDED_BASE_URL=https://api.holded.com/api

# Puerto en el que escucha el backend del super-mini-MVP.
PORT=3001
