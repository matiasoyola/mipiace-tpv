# Copia este archivo a `.env` y rellena los valores.
# El `.env` real está en .gitignore.
#
# Sólo overrides locales del .env de la raíz del repo. La mayoría de
# variables las lee el server desde `<repo>/.env` directamente. Este
# archivo se usa para desarrollo aislado del workspace `apps/api`.

# URL base de la API de Holded (sobrescribe el default).
HOLDED_BASE_URL=https://api.holded.com/api

# Puerto en el que escucha el backend.
PORT=3001
