# Caddyfile · mipiacetpv producción
#
# Topología de dominios (en VPS 3, IP 76.13.142.28):
#
#   Canónico (.com — registrado 2026-05-18):
#     mipiacetpv.com           → PWA del TPV (estáticos /srv/tpv) + /api/* → api:3001
#     admin.mipiacetpv.com     → consola admin per-tenant + super-admin (estáticos /srv/admin) + /api/* → api:3001
#     api.mipiacetpv.com       → backend API directo (proxy a api:3001)
#
#   Legacy (.tech): 301 → .com preservando path. Se mantienen mientras
#   los pilotos antiguos no migren. Decisión 2026-05-18: marca única .com.
#
# Las PWAs hacen fetch a paths relativos `/api/*` para evitar problemas
# CORS y simplificar `PUBLIC_API_URL` en build. El backend también queda
# expuesto en `api.mipiacetpv.com` para herramientas externas (curl,
# Postman) y para WebSockets cuando se conectan desde otros orígenes.
#
# SSL: Caddy obtiene certificados Let's Encrypt automáticamente al primer
# acceso. Los DNS A records de los 6 dominios (.com + .tech) tienen que
# apuntar a 76.13.142.28 ANTES de levantar el stack (si no, Let's
# Encrypt falla y Caddy se queda reintentando cada minuto).

{
	email {$CADDY_ACME_EMAIL}
	# Producción: activa redirección automática HTTP → HTTPS, HSTS, etc.
	# Modo log JSON para integrar con Sentry / agregadores en el futuro.
	log {
		output stdout
		format json
		level INFO
	}
}

# ═══════════════════════════════════════════════════════════════════════
# CANÓNICO · .com
# ═══════════════════════════════════════════════════════════════════════

# ── PWA del TPV ──────────────────────────────────────────────────────
mipiacetpv.com, www.mipiacetpv.com {
	# /api/* se proxea al backend. handle_path elimina el prefijo /api
	# antes de reenviar (la API escucha en rutas sin prefijo).
	handle_path /api/* {
		reverse_proxy api:3001
	}

	# B-TPV-Bugfix v1 · Bug-04: las URLs del PDF público del ticket
	# (las que viajan en el QR / email al cliente final) son del tipo
	# `https://mipiacetpv.com/tickets/<slug>/pdf`. Antes caían a la PWA
	# del TPV (try_files → index.html → pantalla de pairing). Ahora se
	# proxean al backend Fastify que sirve el endpoint público sin auth
	# (ver apps/api/src/tickets/public-pdf-route.ts).
	# Marca canónica .com en los QR sin tener que pasar por
	# api.mipiacetpv.com (más fea para los clientes finales del bar).
	@publicTicketPdf path_regexp ^/tickets/[0-9a-f]{16}/pdf$
	handle @publicTicketPdf {
		reverse_proxy api:3001
	}

	# B-ProductImages: imágenes de producto cacheadas localmente desde
	# Holded. El worker (mipiacetpv-worker) descarga y escribe a
	# /srv/product-images/<tenantId>/<productId>.<ext>. El path lleva
	# UUID v4 (≈122 bits) — adivinar otro tenant+producto es inviable.
	# Cache HTTP de 30 días: si la URL cambia en Holded, el sync
	# incremental invalida `imageCachedAt` y el worker sobrescribe el
	# archivo atomicamente. El service worker de la PWA hace
	# StaleWhileRevalidate sobre estas URLs (B-ProductImages F5).
	handle_path /product-images/* {
		root * /srv/product-images
		file_server
		encode gzip zstd
		header Cache-Control "public, max-age=2592000, immutable"
	}

	# v1.4 Lote 1 (Bug-WS): WS multi-terminal de tickets/mesas/turnos.
	# El path no lleva /api porque el JWT del cashier ya identifica
	# tenant + register, y porque la CSP de la PWA (más abajo) permite
	# wss:// en el mismo dominio. reverse_proxy hace upgrade WebSocket
	# automáticamente — no requiere config extra. Sin esta regla la
	# conexión cae al handler PWA y devuelve index.html (200 HTML),
	# rompiendo el realtime en producción.
	handle /ws/* {
		reverse_proxy api:3001
	}

	handle {
		root * /srv/static/tpv
		encode gzip zstd
		# La PWA usa client-side routing (react-router) — todo lo que no sea
		# un archivo se rebota a index.html para que React maneje la ruta.
		try_files {path} /index.html
		file_server

		# Service worker no se cachea: tiene que llegar siempre fresco para
		# que el cliente reciba versiones nuevas.
		@sw path /sw.js /service-worker.js /workbox-*.js
		header @sw Cache-Control "no-cache, no-store, must-revalidate"

		# Resto de assets con hash: cache largo.
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# Security headers
		# B-Hardening A · S1 + S7:
		#   - CSP defensiva: scripts/conexiones/imágenes acotadas al
		#     propio dominio + el host de la API. 'unsafe-inline' sólo
		#     en style-src porque Tailwind lo necesita. wss para los
		#     WebSockets futuros de mesas multi-terminal.
		#   - Permissions-Policy ampliada: bloquea cohort FLoC, deja
		#     payment/usb/bluetooth en 'self' para futuras integraciones
		#     de lector USB-HID / pago contactless.
		header {
			Strict-Transport-Security "max-age=31536000; includeSubDomains"
			X-Content-Type-Options "nosniff"
			X-Frame-Options "DENY"
			Referrer-Policy "strict-origin-when-cross-origin"
			Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=(), payment=(self), usb=(self), bluetooth=(self)"
			Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' https://api.mipiacetpv.com wss://api.mipiacetpv.com wss://mipiacetpv.com wss://admin.mipiacetpv.com; font-src 'self' data:; frame-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'self' blob:"
		}
	}
}

# ── Consola admin (per-tenant + super-admin en /superadmin) ──────────
admin.mipiacetpv.com {
	handle_path /api/* {
		reverse_proxy api:3001
	}

	# B-ProductImages: el admin también pinta el catálogo con imágenes
	# (vista de productos / bandeja de revisión). Mismo volumen RO.
	handle_path /product-images/* {
		root * /srv/product-images
		file_server
		encode gzip zstd
		header Cache-Control "public, max-age=2592000, immutable"
	}

	# v1.4 Lote 1 (Bug-WS): mismo handle /ws/* que en mipiacetpv.com
	# por si en el futuro el admin abre un panel realtime (KDS,
	# dashboard live de ventas, etc.). Hoy ningún cliente del admin
	# abre WS, pero dejar la regla evita un segundo deploy de Caddy.
	handle /ws/* {
		reverse_proxy api:3001
	}

	handle {
		root * /srv/static/admin
		encode gzip zstd
		try_files {path} /index.html
		file_server

		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# B-Hardening A · S1 + S7: CSP + Permissions-Policy ampliada
		# en el admin. Mismo razonamiento que el bloque del TPV. El
		# admin también consume la API directa (admin.mipiacetpv.com
		# hace fetch a /api/* y a api.mipiacetpv.com en algunos flujos),
		# por eso connect-src incluye ambos hosts.
		header {
			Strict-Transport-Security "max-age=31536000; includeSubDomains"
			X-Content-Type-Options "nosniff"
			X-Frame-Options "DENY"
			Referrer-Policy "strict-origin-when-cross-origin"
			Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=(), payment=(self), usb=(self), bluetooth=(self)"
			Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' https://api.mipiacetpv.com wss://api.mipiacetpv.com wss://mipiacetpv.com wss://admin.mipiacetpv.com; font-src 'self' data:; frame-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'self' blob:"
		}
	}
}

# ── Backend API directo ──────────────────────────────────────────────
# WebSockets de B7 (mesas multi-terminal) pasan por aquí. Caddy detecta
# el Upgrade header y proxea WS transparentemente.
api.mipiacetpv.com {
	encode gzip zstd
	reverse_proxy api:3001

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
	}
}

# ═══════════════════════════════════════════════════════════════════════
# LEGACY · .tech → 301 al .com (preserva path + query string).
# Mantener mientras los pilotos antiguos no migren. Eliminar cuando
# Google Search Console confirme que ya no hay tráfico al .tech.
# ═══════════════════════════════════════════════════════════════════════

mipiacetpv.tech, www.mipiacetpv.tech {
	redir https://mipiacetpv.com{uri} permanent
}

admin.mipiacetpv.tech {
	redir https://admin.mipiacetpv.com{uri} permanent
}

api.mipiacetpv.tech {
	redir https://api.mipiacetpv.com{uri} permanent
}
