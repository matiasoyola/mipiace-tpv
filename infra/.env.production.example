# Variables de entorno para producción · mipiacetpv
#
# Copiar a `infra/.env.production` y rellenar los secretos antes de
# `docker compose --env-file infra/.env.production -f infra/docker-compose.prod.yml up -d`.
#
# Genera secretos así (en tu Mac o en el VPS):
#   JWT_ACCESS_SECRET / JWT_REFRESH_SECRET / SUPER_ADMIN_JWT_SECRET:
#     openssl rand -base64 48
#   HOLDED_KEY_ENCRYPTION_SECRET:
#     openssl rand -base64 32
#   POSTGRES_PASSWORD:
#     openssl rand -base64 32 | tr -d '/+=' | cut -c1-32

# ── Postgres (interno del compose) ──────────────────────────────────
POSTGRES_USER=mipiacetpv
POSTGRES_PASSWORD=REPLACE_ME_with_openssl_rand_base64_32
POSTGRES_DB=mipiacetpv

# ── URLs públicas ───────────────────────────────────────────────────
# Caddy enruta estos dominios al stack interno (ver Caddyfile).
# Canónico .com (2026-05-18); el .tech hace 301 → .com.
PUBLIC_ADMIN_URL=https://admin.mipiacetpv.com
PUBLIC_TICKET_URL=https://api.mipiacetpv.com

# Orígenes permitidos por CORS — incluir la PWA (root) y el admin.
# Los .tech permanecen para no romper PWAs cacheadas durante la
# transición; el 301 las redirigirá al .com en la siguiente carga.
CORS_ORIGINS=https://mipiacetpv.com,https://www.mipiacetpv.com,https://admin.mipiacetpv.com,https://mipiacetpv.tech,https://www.mipiacetpv.tech,https://admin.mipiacetpv.tech

# Email del propietario para Let's Encrypt (notificaciones de expiración SSL).
CADDY_ACME_EMAIL=m.oyola@mipiace.es

# ── JWT secrets (40+ chars cada uno, todos distintos) ───────────────
JWT_ACCESS_SECRET=REPLACE_ME_openssl_rand_base64_48
JWT_REFRESH_SECRET=REPLACE_ME_openssl_rand_base64_48
SUPER_ADMIN_JWT_SECRET=REPLACE_ME_openssl_rand_base64_48

# ── Cifrado de API keys de Holded (AES-256-GCM, 32 bytes base64) ────
HOLDED_KEY_ENCRYPTION_SECRET=REPLACE_ME_openssl_rand_base64_32

# ── Email transaccional ─────────────────────────────────────────────
# Resend recomendado para producción. Configurar dominio mipiacetpv.com
# como sending domain en Resend, añadir los DNS records (SPF, DKIM) y
# usar SMTP relay con las credenciales de aquí.
#
# Mientras no esté Resend listo, dejar vacío SMTP_HOST: la API caerá al
# ConsoleEmailSender (los emails se logean pero no se envían) — vale
# para empezar a probar el flujo de alta sin que Thalia reciba todavía.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=REPLACE_ME_resend_api_key
SMTP_FROM=noreply@mipiacetpv.com

# Remitente / reply-to del email de bienvenida del super-admin a OWNERs.
SUPER_ADMIN_FROM_EMAIL=noreply@mipiacetpv.com
SUPER_ADMIN_REPLY_TO_EMAIL=soporte@mipiacetpv.com
